{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RegressionAnalysisReport",
  "type": "object",
  "properties": {
    "checkpoint_id": { "type": "string" },
    "comparison_checkpoint_id": { "type": "string" },
    "status": { "type": "string", "enum": ["pass", "regression_detected", "improvement_detected"] },
    "regressions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "metric_name": { "type": "string" },
          "baseline_value": { "type": "number" },
          "current_value": { "type": "number" },
          "pct_change": { "type": "number" },
          "severity": { "type": "string", "enum": ["warning", "critical"] }
        },
        "required": ["metric_name", "baseline_value", "current_value", "pct_change", "severity"]
      }
    }
  },
  "required": ["checkpoint_id", "comparison_checkpoint_id", "status", "regressions"]
}
